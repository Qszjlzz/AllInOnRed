    "index": 1
  },
  {
    "t": 22.995,
    "event": "segment_start",
    "segmentIndex": 3,
    "text": "第一按就赢，第二按又赢。“就一下”一下子变得特别有道理。",
    "duration": 5.16
  },
  {
    "t": 24.469,
    "event": "armed",
